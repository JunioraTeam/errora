{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": ["src/**", "__tests__/**", "*.ts", "*.mjs", "*.json"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noArrayIndexKey": "off" },
      "a11y": { "useKeyWithClickEvents": "off" }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "trailingCommas": "es5", "semicolons": "always" }
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } }
}
