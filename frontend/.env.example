# ============================================================================
# Errora frontend — environment configuration.
#   cp .env.example .env.local
# Only NEXT_PUBLIC_* vars are exposed to the browser bundle.
# ============================================================================

# Base URL of the Errora backend. The API client appends /api/v1, and SDKs
# post events to {NEXT_PUBLIC_API_URL}/api/<project_id>/store/.
NEXT_PUBLIC_API_URL=http://localhost:8000
