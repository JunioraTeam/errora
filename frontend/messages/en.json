  "landing": {
    "hero": {
      "badge": "Next-gen error tracking",
      "titleLine1": "Catch errors before",
      "titleLine2": "your users do",
      "subtitle": "Errora groups your exceptions, measures performance, and proposes AI-powered fixes. Built-in GitLab integration, ready for Persian-speaking teams.",
      "ctaPrimary": "Start for free",
      "ctaSecondary": "See pricing",
      "trustedBy": "Trusted by engineering teams"
    },
    "stats": {
      "events": "events processed",
      "uptime": "uptime",
      "latency": "avg ingest latency"
    },
    "features": {
      "title": "Everything you need to fix errors",
      "subtitle": "From capture to resolution, one cohesive workflow.",
      "grouping": {
        "title": "Smart grouping",
        "desc": "Similar exceptions are automatically merged into a single issue, killing the noise so you see the real trend."
      },
      "performance": {
        "title": "Performance monitoring",
        "desc": "Surface slow transactions, heavy queries, and high-latency routes with distributed tracing."
      },
      "autofix": {
        "title": "AI auto-fix",
        "desc": "Errora's AI engine analyzes the root cause and proposes a corrective merge request on GitLab."
      },
      "integrations": {
        "title": "GitLab integration",
        "desc": "Link issues to commits and merge requests, and automate release tracking."
      },
      "alerts": {
        "title": "Alerts & webhooks",
        "desc": "Get notified via webhook, email, or your favorite channel on new errors or error-rate spikes."
      },
      "stacktrace": {
        "title": "Rich stack traces",
        "desc": "Full stack frames with in-app highlighting, line numbers, and surrounding context for fast debugging."
      },
      "logs": {
        "title": "Structured logs",
        "desc": "Ship logs alongside errors — searchable, level-filtered, tagged, and correlated to traces. No separate logging stack."
      },
      "mcp": {
        "title": "AI agent access (MCP)",
        "desc": "An MCP server lets agents like Claude and Cursor query projects, inspect issues + stack traces, and resolve them — authed by personal access tokens."
      },
      "sourcemaps": {
        "title": "Source maps & symbolication",
        "desc": "Upload release artifacts and minified JavaScript stack frames are mapped back to original files, lines, and source context."
      },
      "search": {
        "title": "Full-text search",
        "desc": "Fast issue and log search powered by native full-text indexing (PostgreSQL / MySQL / SQLite) with a graceful fallback everywhere else."
      },
      "issueTracking": {
        "title": "GitLab issue tracking",
        "desc": "Create a GitLab issue from an error or link an existing one — prefilled title and description, two-way from the issue page."
      },
      "retention": {
        "title": "Data retention controls",
        "desc": "Set how long events are kept per organization; a nightly job purges expired data automatically, with a sensible global default."
      }
    },
    "autofixSection": {
      "badge": "AI powered",
      "title": "Let AI fix the error for you",
      "desc": "With one click, Errora analyzes the full error context — stack trace, event, tags, and related code — and produces a proposed fix with an explanation.",
