# Version control / CI
.git
.gitignore
.github

# Dependencies (reinstalled inside the image)
node_modules/
.pnpm-store/

# Build output (regenerated by `next build`)
.next/
out/
dist/
build/

# Local config & secrets — never bake into the image
.env
.env.*
!.env.example

# Logs & caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.turbo/
*.tsbuildinfo

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# Docs & local-only files
*.md
README*
