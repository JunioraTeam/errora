# ============================================================================
# Errora — environment configuration. Copy to `.env` and fill in.
#   cp .env.example .env
# Everything is read by the Django backend (django-environ) and docker-compose.
# ============================================================================

# --- Core -------------------------------------------------------------------
# In production set DEBUG=0 — the app then REFUSES to boot unless SECRET_KEY and
# SECRETS_ENCRYPTION_KEY (below) are set to real values.
DEBUG=1
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
LANGUAGE_CODE=fa
TIME_ZONE=Asia/Tehran

# --- Database (Postgres) ----------------------------------------------------
POSTGRES_USER=errora
POSTGRES_PASSWORD=errora
POSTGRES_DB=errora
DATABASE_URL=postgres://errora:errora@db:5432/errora

# --- Redis (cache + Celery broker — NOT Kafka, per design) ------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# --- Auth / JWT -------------------------------------------------------------
JWT_SECRET=change-me-too
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14

# --- Secrets encryption (Fernet key, base64 32 bytes) -----------------------
# REQUIRED when DEBUG=0 (the app won't boot without it). Without it, stored
# integration tokens / AI keys would be encrypted under a key derived from
# SECRET_KEY — i.e. effectively plaintext.
# Generate: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# --- Ingest edge limits & outbound SSRF guard -------------------------------
# Max decompressed ingest body (gzip/deflate bomb guard). Max accepted payload.
INGEST_MAX_DECOMPRESSED_BYTES=20000000
INGEST_MAX_PAYLOAD_BYTES=1000000
# Per-project events/min (0 = off).
INGEST_RATE_LIMIT_PER_MIN=0
# Outbound URLs (webhooks, AI/GitLab base_url) always block loopback/metadata.
# Set to 1 on multi-tenant deployments to ALSO block private/internal ranges
# (leave 0 for self-host so internal GitLab/Mattermost/LLM integrations work).
SSRF_BLOCK_PRIVATE=0

# --- OTP / SMS (provider is swappable; Kavenegar for +98) -------------------
SMS_PROVIDER=kavenegar
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=errora-otp
OTP_TTL_SECONDS=120
OTP_LENGTH=6
DEFAULT_PHONE_REGION=+98

# --- Email ------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@errora.dev

# --- AI auto-fix (Seer-like) ------------------------------------------------
# Per-org/project keys are stored encrypted in the DB; this is only the default.
AI_DEFAULT_PROVIDER=claude
AI_REQUEST_TIMEOUT=120

# --- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
