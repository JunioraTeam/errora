# ============================================================================
# Errora backend — environment configuration.
#   cp .env.example .env   (this file is loaded automatically by errora/settings.py)
# All values have sensible defaults in settings.py; override here as needed.
# ============================================================================

# --- Core -------------------------------------------------------------------
DEBUG=1
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*
SITE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
LANGUAGE_CODE=fa
TIME_ZONE=Asia/Tehran
LOG_LEVEL=INFO

# --- Database ---------------------------------------------------------------
# Local testing (no Postgres needed) — file created in the backend/ directory:
DATABASE_URL=sqlite:///db.sqlite3
# Production / docker-compose:
# DATABASE_URL=postgres://errora:errora@db:5432/errora
DB_CONN_MAX_AGE=60

# Raise the process file-descriptor soft limit at startup (best-effort). IDE/
# launchd-spawned servers inherit a tiny default (256 on macOS), causing
# "Too many open files" under load. Set 0 to disable the bump.
FD_SOFT_LIMIT=65536

# Seconds to cache the AI-agents / MCP dashboard aggregations (0 disables).
INSIGHTS_OVERVIEW_CACHE_TTL=30

# --- Redis (cache + Celery broker — not Kafka, by design) -------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
USAGE_FLUSH_INTERVAL=300

# --- Auth / JWT -------------------------------------------------------------
JWT_SECRET=change-me-too
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=14
# Allow new account creation. Set to 0 to freeze signup (existing users can
# still log in; unknown identifiers are rejected).
SIGNUP_ENABLED=1
# Rate limit for password login & signup, per client IP (DRF throttle syntax).
AUTH_THROTTLE_RATE=10/min

# --- Secrets encryption (Fernet key, base64 32 bytes) -----------------------
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# --- OTP / SMS (provider swappable; Kavenegar for +98) ----------------------
SMS_PROVIDER=kavenegar
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=errora-otp
OTP_TTL_SECONDS=120
OTP_LENGTH=6
DEFAULT_PHONE_REGION=+98
# Dev convenience: emit a fixed all-ones code (e.g. 111111). Defaults to DEBUG.
OTP_DEBUG_CODE=1

# --- Email ------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=no-reply@errora.dev

# --- AI auto-fix (Seer-like) ------------------------------------------------
# Per-org/project keys are stored encrypted in the DB; this is only the default.
AI_DEFAULT_PROVIDER=claude
AI_REQUEST_TIMEOUT=120
