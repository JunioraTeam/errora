# Version control / CI
.git
.gitignore
.github

# Python caches & build artifacts
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Virtualenvs
.venv/
venv/
env/

# Collected static (regenerated inside the image via collectstatic)
staticfiles/

# Local config & secrets — never bake into the image
.env
.env.*
*.local

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# Docs & local-only files
*.md
.specstory/
